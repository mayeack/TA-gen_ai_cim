#
# default.meta - Permissions and metadata
# TA-gen_ai_cim
#
# Updated: Added ServiceNow AI Case Management integration permissions
#

# Global settings
[]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Views (if any dashboards are added)
[views]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# Saved searches
[savedsearches]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# Lookups (if any are added)
[lookups]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Macros (if any are added)
[macros]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# KV Store collections
[collections]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# KV Store lookup transforms
[transforms/genai_token_cost_lookup]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

###############################################################################
# SERVICENOW AI CASE MANAGEMENT INTEGRATION PERMISSIONS
###############################################################################

# ServiceNow case mapping KV Store lookup
[transforms/gen_ai_snow_case_map_lookup]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# ServiceNow case mapping KV Store collection
# Allow power users to create cases, admin to manage
[collections/gen_ai_snow_case_map]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# Custom search command - aicase
# Restricted to the same trusted roles as the open_case_in_servicenow workflow
# action and the gen_ai_snow_case_map collection (power users create cases,
# admins manage). Ordinary search users must not invoke | aicase directly: it
# fetches event content and creates external ServiceNow cases under the
# invoking user's session. Grant additional roles per-environment via local.meta.
[commands/aicase]
access = read : [ admin, sc_admin, power ], write : [ admin, sc_admin ]
export = system

# Workflow actions for Event Context menu
[workflow_actions]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Specific workflow action permissions
[workflow_actions/open_case_in_servicenow]
access = read : [ power, admin, sc_admin ], write : [ admin, sc_admin ]
export = system

# ServiceNow case redirect view
[views/servicenow_case]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# ServiceNow account configuration (conf file)
[conf/ta_gen_ai_cim_account]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = none

[configs/conf-ta_gen_ai_cim_account]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = none

# REST endpoint for account management
[admin:ta_gen_ai_cim_account]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = none

[admin_external:ta_gen_ai_cim_account]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = none

###############################################################################
# AI GOVERNANCE REVIEW INTEGRATION PERMISSIONS
###############################################################################

# Review findings KV Store collection - ai_reviewers can write
[collections/gen_ai_review_findings]
access = read : [ * ], write : [ admin, sc_admin, ai_reviewers, power ]
export = system

# Review audit log KV Store collection
[collections/gen_ai_review_audit]
access = read : [ * ], write : [ admin, sc_admin, ai_reviewers ]
export = system

# Review findings lookup transform - ai_reviewers can write
[transforms/gen_ai_review_findings_lookup]
access = read : [ * ], write : [ admin, sc_admin, ai_reviewers ]
export = system

# Review audit lookup transform
[transforms/gen_ai_review_audit_lookup]
access = read : [ * ], write : [ admin, sc_admin, ai_reviewers ]
export = system

# Open AI Review workflow action - available to all users
[workflow_actions/1_open_ai_review]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Review Queue dashboard
[views/review_queue]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# Event Review form
[views/event_review]
access = read : [ * ], write : [ admin, sc_admin, power ]
export = system

# Navigation
[nav]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

# Authorization (ai_reviewers role)
[authorize]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

###############################################################################
# GENAI SCORING PIPELINE PERMISSIONS
###############################################################################

# GenAI scoring configuration (conf file)
[conf/ta_gen_ai_cim_genai_scoring]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = none

[configs/conf-ta_gen_ai_cim_genai_scoring]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = none

# GenAI scoring configuration view
[views/genai_scoring_config]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = system

# GenAI scoring custom search command
# Admin-only: the command reads the admin-restricted
# ta_gen_ai_cim_genai_scoring.conf and sends event content to the configured
# LLM provider. The scoring pipelines that call it are admin-owned saved
# searches (see savedsearches stanzas below), so no non-admin path needs it.
[commands/genaiscore]
access = read : [ admin, sc_admin ], write : [ admin, sc_admin ]
export = system

# GenAI scoring pipeline saved searches must be owned by a real user (admin)
# so the scheduler runs them with a valid, authenticated session. The
# genaiscore command reads ta_gen_ai_cim_genai_scoring.conf over REST, and that
# conf is restricted to read:[admin]; a nobody-owned scheduled search fails
# config load with "Session is not logged in" and silently drops every event
# (genai_scoring_status=error gets filtered out). Owning as admin fixes it.
[savedsearches/GenAI%20Scoring%20-%20Pipeline%201]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%202]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%203]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%204]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%205]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%206]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%207]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%208]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%209]
owner = admin

[savedsearches/GenAI%20Scoring%20-%20Pipeline%2010]
owner = admin

###############################################################################
# EVENTTYPE AND TAG PERMISSIONS
###############################################################################

[eventtypes]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[tags]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[datamodels]
access = read : [ * ], write : [ admin, sc_admin ]
export = system
