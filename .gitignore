# Local configuration (contains instance-specific settings and credentials)
local/
metadata/local.meta

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Splunk-generated ML models (large binary files)
lookups/*.mlmodel

# Lookup data files: ignore only large/generated datasets. Small synthetic
# sample CSVs (medadvice_*, prompt_injection_training_examples) are tracked
# and shipped because transforms.conf / inputs.conf reference them.
lookups/llm_pii_mixed_responses_200k.csv
lookups/*_training_data_engineered.csv
lookups/tfidf_training_data_v3.csv
lookups/*_model_metadata.csv
lookups/pii_training_examples.csv

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# Log files
*.log
# ...except sample event logs intentionally shipped for testing
!samples/*.log

# Planning documents (AI assistant collaboration)
planning/

# Key Features documentation (AI-generated, instance-specific)
README/KEY_FEATURES.md

# Environment files
.env
.env.*

# Cursor MCP config (instance-specific, may contain credentials)
.cursor/mcp.json

# Claude Code local settings (instance-specific)
.claude/settings.local.json
