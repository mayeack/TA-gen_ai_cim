<form version="1.1">
  <label>AI Observability - Overview Dashboard</label>
  <description>Comprehensive GenAI inference monitoring across all providers</description>

  <fieldset submitButton="true" autoRun="true">
    <input type="time" token="time_picker">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="provider_filter">
      <label>Provider</label>
      <choice value="*">All Providers</choice>
      <choice value="anthropic">Anthropic</choice>
      <choice value="openai">OpenAI</choice>
      <choice value="bedrock">AWS Bedrock</choice>
      <choice value="internal">Internal</choice>
      <default>*</default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Total AI Requests</title>
      <single>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | stats count</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Total Calls</option>
      </single>
    </panel>
    <panel>
      <title>Total Tokens Processed</title>
      <single>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | stats sum(gen_ai.usage.total_tokens) as total | eval total=tostring(total, "commas")</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="underLabel">Tokens</option>
      </single>
    </panel>
    <panel>
      <title>Estimated Cost (USD)</title>
      <single>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ `gen_ai_calculate_cost` | stats sum(gen_ai.cost.calculated_total) as total_cost | eval total_cost="$"+tostring(round(total_cost, 2), "commas")</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="underLabel">Total Spend</option>
      </single>
    </panel>
    <panel>
      <title>Avg Latency (sec)</title>
      <single>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | stats avg(gen_ai.client.operation.duration) as avg_latency | eval avg_latency=round(avg_latency, 3)</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="underLabel">Seconds</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Requests Over Time by Provider</title>
      <chart>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | timechart count by gen_ai.provider.name</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Request Count</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Latency Trends (p50, p95, p99)</title>
      <chart>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | timechart perc50(gen_ai.client.operation.duration) as p50, perc95(gen_ai.client.operation.duration) as p95, perc99(gen_ai.client.operation.duration) as p99</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Latency (sec)</option>
        <option name="charting.legend.placement">bottom</option>
      </chart>
    </panel>
    <panel>
      <title>Token Usage Trends</title>
      <chart>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | timechart sum(gen_ai.usage.total_tokens) as total_tokens</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Total Tokens</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top Models by Request Volume</title>
      <table>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ `gen_ai_enrich_metadata`
| stats count as requests,
    sum(gen_ai.usage.total_tokens) as total_tokens,
    sum(gen_ai.cost.calculated_total) as total_cost,
    avg(gen_ai.client.operation.duration) as avg_latency_sec,
    perc95(gen_ai.client.operation.duration) as p95_latency_sec
    by gen_ai.provider.name, gen_ai.request.model
| eval total_cost=round(total_cost, 2), avg_latency_sec=round(avg_latency_sec, 3), p95_latency_sec=round(p95_latency_sec, 3)
| sort - requests</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="count">10</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Cost Distribution by Provider</title>
      <chart>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ `gen_ai_calculate_cost` | stats sum(gen_ai.cost.calculated_total) as total_cost by gen_ai.provider.name | eval total_cost=round(total_cost, 2)</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
    <panel>
      <title>Request Distribution by Model</title>
      <chart>
        <search>
          <query>`gen_ai_base` gen_ai.provider.name=$provider_filter$ | stats count by gen_ai.request.model | sort - count | head 10</query>
          <earliest>$time_picker.earliest$</earliest>
          <latest>$time_picker.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
  </row>
</form>
